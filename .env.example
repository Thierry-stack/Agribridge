# Copy this file to ".env.local" and fill in real values.
# Next.js loads .env.local automatically (never commit .env.local).

# MongoDB connection string
# Local (MongoDB installed on your PC): mongodb://127.0.0.1:27017/agribridge
# Atlas: copy from Database → Connect → Drivers (it URL-encodes special chars in the password).
# If the password contains @ : / ? # [ ] you MUST encode them (e.g. @ → %40) or the URI breaks.
MONGODB_URI=

# Used to sign login cookies (JWT). Use a long random string in production.
JWT_SECRET=
